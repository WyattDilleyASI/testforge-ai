  <div class=3D"Section1">
   <table class=3D"grid" cellpadding=3D"0" cellspacing=3D"0" border=3D"0" width=3D"100%">
    <tbody>
     <tr>
      <td bgcolor=3D"f0f0f0" colspan=3D"2" valign=3D"top"><h3 class=3D"formtitle">LFWM2-VERTCA-40 <a href=3D"perspective.req?projectId=3D152&amp;docId=3D5149615"> VCU: Truth Table - Autonomous Mode | Remote EStopped | TealSlow Beacon </a>&nbsp; 
        <div class=3D"subText">
         Created: <font color=3D"336699">11/13/2025 01:59:47 AM UTC</font> &nbsp;Updated: <font color=3D"336699">01/27/2026 10:46:21 AM UTC</font>
        </div></h3></td>
     </tr>
     <tr bgcolor=3D"ffffff">
      <td width=3D"20%"><b>Project ID:</b></td>
      <td bgcolor=3D"ffffff" width=3D"80%">LFWM2-VERTCA-40</td>
     </tr>
     <tr bgcolor=3D"ffffff">
      <td width=3D"20%"><b>Global ID:</b></td>
      <td bgcolor=3D"ffffff" width=3D"80%">GID-3326993</td>
     </tr>
     <tr bgcolor=3D"ffffff">
      <td width=3D"20%"><b>Name:</b></td>
      <td bgcolor=3D"ffffff" width=3D"80%">VCU: Truth Table - Autonomous Mode | Remote EStopped | TealSlow Beacon</td>
