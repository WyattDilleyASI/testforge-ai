     <tr>
      <td bgcolor=3D"f0f0f0" colspan=3D"2" valign=3D"top"><h3 class=3D"formtitle">LFWM2-CMP-22685 <a href=3D"perspective.req?projectId=3D152&amp;docId=3D5101027"> Manual Test Cases </a>&nbsp; 
        <div class=3D"subText">
         Created: <font color=3D"336699">10/16/2025 04:25:26 PM UTC</font> &nbsp;Updated: <font color=3D"336699">10/16/2025 04:25:26 PM UTC</font>
